#!/bin/bash
DATA_DIR="${DATA_DIR:-/data}"
USERS_FILE="$DATA_DIR/users.txt"


G='\033[1;32m'
C='\033[1;36m'
Y='\033[1;33m'
P='\033[1;35m'
R='\033[1;31m'
W='\033[1;37m'
D='\033[2m'
N='\033[0m'

# Border tebal sesuai request:
# ┃ ━ ┏ ┓ ┗ ┛
# Lebar dibuat 38 karakter supaya rapi di terminal HP.
box_top() {
  echo -e "${P}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${N}"
}

box_sep() {
  echo -e "${P}┃━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┃${N}"
}

box_bottom() {
  echo -e "${P}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${N}"
}

box_line() {
  local text="$1"
  local color="${2:-$W}"
  text="${text:0:36}"
  printf "${P}┃${N} ${color}%-36s${N} ${P}┃${N}\n" "$text"
}

title_box() {
  local title="$1"
  local color="${2:-$C}"
  box_top
  box_line "$title" "$color"
  box_bottom
}

pause_back() {
  echo ""
  read -rp "$(echo -e "${D}Enter untuk kembali...${N}")" _
}


mkdir -p "$DATA_DIR"
touch "$USERS_FILE"

title_box "HAPUS SSH USER" "$Y"

if [ ! -s "$USERS_FILE" ]; then
  echo -e "${Y}Belum ada user SSH.${N}"
  exit 0
fi

echo ""
echo -e "${C}Daftar user:${N}"
echo -e "${P}┏━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┓${N}"
printf "${P}┃${N} ${W}%-14s${N} ${P}┃${N} ${W}%-10s${N} ${P}┃${N}\n" "USERNAME" "EXPIRED"
echo -e "${P}┃━━━━━━━━━━━━━━━━╋━━━━━━━━━━━━┃${N}"

while IFS=: read -r USERNAME PASSWORD EXP_DATE; do
  [ -z "$USERNAME" ] && continue
  printf "${P}┃${N} ${G}%-14.14s${N} ${P}┃${N} ${Y}%-10s${N} ${P}┃${N}\n" "$USERNAME" "${EXP_DATE:-unknown}"
done < "$USERS_FILE"

echo -e "${P}┗━━━━━━━━━━━━━━━━┻━━━━━━━━━━━━┛${N}"
echo ""

read -rp "$(echo -e "${C}Username yang dihapus ${Y}: ${N}")" USERNAME
[ -z "$USERNAME" ] && echo -e "${R}Username kosong.${N}" && exit 1

if ! grep -q "^${USERNAME}:" "$USERS_FILE"; then
  echo -e "${R}User tidak ditemukan di database.${N}"
  exit 1
fi

read -rp "$(echo -e "${R}Ketik DELETE untuk konfirmasi ${Y}: ${N}")" CONFIRM
if [ "$CONFIRM" != "DELETE" ]; then
  echo -e "${Y}Dibatalkan.${N}"
  exit 0
fi

userdel -f "$USERNAME" >/dev/null 2>&1 || true

TMP_FILE="$USERS_FILE.tmp"
grep -v "^${USERNAME}:" "$USERS_FILE" > "$TMP_FILE" 2>/dev/null || true
mv "$TMP_FILE" "$USERS_FILE"

echo ""
box_top
box_line "USER BERHASIL DIHAPUS" "$G"
box_sep
box_line "Username : $USERNAME" "$C"
box_bottom
