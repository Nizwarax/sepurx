#!/bin/bash
DATA_DIR="${DATA_DIR:-/data}"
USERS_FILE="$DATA_DIR/users.txt"


G='\033[1;32m'
C='\033[1;36m'
Y='\033[1;33m'
P='\033[1;35m'
R='\033[1;31m'
W='\033[1;37m'
D='\033[2m'
N='\033[0m'

# Border tebal sesuai request:
# ┃ ━ ┏ ┓ ┗ ┛
# Lebar dibuat 38 karakter supaya rapi di terminal HP.
box_top() {
  echo -e "${P}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${N}"
}

box_sep() {
  echo -e "${P}┃━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┃${N}"
}

box_bottom() {
  echo -e "${P}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${N}"
}

box_line() {
  local text="$1"
  local color="${2:-$W}"
  text="${text:0:36}"
  printf "${P}┃${N} ${color}%-36s${N} ${P}┃${N}\n" "$text"
}

title_box() {
  local title="$1"
  local color="${2:-$C}"
  box_top
  box_line "$title" "$color"
  box_bottom
}

pause_back() {
  echo ""
  read -rp "$(echo -e "${D}Enter untuk kembali...${N}")" _
}


mkdir -p "$DATA_DIR"
touch "$USERS_FILE"

title_box "CLEAN EXPIRED USER" "$P"

TODAY="$(date +%F)"
TMP_FILE="$USERS_FILE.tmp"
: > "$TMP_FILE"

CLEANED=0
KEPT=0

echo ""
while IFS=: read -r USERNAME PASSWORD EXP_DATE; do
  [ -z "$USERNAME" ] && continue
  [ -z "$EXP_DATE" ] && EXP_DATE="$TODAY"

  if [ "$EXP_DATE" \< "$TODAY" ]; then
    userdel -f "$USERNAME" >/dev/null 2>&1 || true
    CLEANED=$((CLEANED + 1))
    echo -e "${R}Dihapus expired${N}: ${W}${USERNAME}${N} ${D}(${EXP_DATE})${N}"
  else
    echo "$USERNAME:$PASSWORD:$EXP_DATE" >> "$TMP_FILE"
    KEPT=$((KEPT + 1))
  fi
done < "$USERS_FILE"

mv "$TMP_FILE" "$USERS_FILE"

echo ""
box_top
box_line "CLEAN SELESAI" "$G"
box_sep
box_line "User aktif tersisa : $KEPT" "$C"
box_line "User expired hapus : $CLEANED" "$R"
box_bottom
